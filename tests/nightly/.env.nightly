# Self-contained .env for nightly CI runs.
# conftest.py writes this to ./.env when the host doesn't already have one.
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora
POSTGRES_DB=agora_cms

AGORA_CMS_DATABASE_URL=postgresql+asyncpg://agora:agora@db:5432/agora_cms
AGORA_CMS_SECRET_KEY=nightly-e2e-not-a-real-secret
AGORA_CMS_ADMIN_USERNAME=admin
AGORA_CMS_ADMIN_PASSWORD=nightly-testpass
AGORA_CMS_API_KEY_ROTATION_HOURS=0
