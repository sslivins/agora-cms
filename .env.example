# Agora CMS environment variables
# Copy to .env and fill in real values: cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora
POSTGRES_DB=agora_cms

# ── CMS (prefix: AGORA_CMS_) ──
AGORA_CMS_DATABASE_URL=postgresql+asyncpg://agora:agora@db:5432/agora_cms
AGORA_CMS_SECRET_KEY=change-me-to-a-random-string
AGORA_CMS_ADMIN_USERNAME=admin
AGORA_CMS_ADMIN_PASSWORD=change-me-to-a-secure-password
AGORA_CMS_API_KEY_ROTATION_HOURS=24

# Uncomment to reset admin password to AGORA_CMS_ADMIN_PASSWORD on next restart
# AGORA_CMS_RESET_PASSWORD=true
