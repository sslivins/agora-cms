# Agora CMS environment variables
# Copy to .env and fill in real values: cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora
POSTGRES_DB=agora_cms

# ── CMS (prefix: AGORA_CMS_) ──
AGORA_CMS_DATABASE_URL=postgresql+asyncpg://agora:agora@db:5432/agora_cms
AGORA_CMS_SECRET_KEY=change-me-to-a-random-string
AGORA_CMS_ADMIN_USERNAME=admin
AGORA_CMS_ADMIN_PASSWORD=change-me-to-a-secure-password
AGORA_CMS_API_KEY_ROTATION_HOURS=24

# Optional — override the base URL for asset download links sent to devices.
# If unset, derived from the device's WebSocket Host header.
# Examples: https://cdn.example.com, http://192.168.1.198:8080
# AGORA_CMS_ASSET_BASE_URL=http://192.168.1.198:8080

# Uncomment to reset admin password to AGORA_CMS_ADMIN_PASSWORD on next restart
# AGORA_CMS_RESET_PASSWORD=true

# ── Storage Backend ──
# "local" (default) — files on disk/Docker volume
# "azure" — sync to Azure Blob Storage, serve devices via SAS URLs
# AGORA_CMS_STORAGE_BACKEND=local

# Azure Blob Storage (required when STORAGE_BACKEND=azure)
# AGORA_CMS_AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AGORA_CMS_AZURE_SAS_EXPIRY_HOURS=1

# ── MCP Server ──
# API key for the MCP server to authenticate with the CMS REST API.
# Generate one from Settings → API Keys, then paste it here.
# CMS_API_KEY=agora_your_key_here
